# GreenChain AI Inference Configuration
# Copy this file to .env and fill in your actual values

# The base URL for the LLM API router (e.g., Hugging Face router)
API_BASE_URL="https://router.huggingface.co/v1"

# Your Hugging Face or OpenAI API Key
HF_TOKEN="your_hf_token_here"
# Alternatively, you can use API_KEY instead of HF_TOKEN
# API_KEY="your_api_key_here"

# The specific model you want to query for the hackathon
MODEL_NAME="meta-llama/Llama-3-70b-chat-hf"
